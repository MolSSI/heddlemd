#[test] // rq-74aa3a99
fn reject_zero_lz() {
    let err = SimulationBox::new(10.0, 8.0, 0.0, 0.0, 0.0, 0.0).expect_err("err");
    match err {
        SimulationBoxError::NonPositiveDiagonal { name, value } => {
            assert_eq!(name, "lz");
            assert_eq!(value, 0.0);
        }
        other => panic!("unexpected error: {other:?}"),
    }
}

